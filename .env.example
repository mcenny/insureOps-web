# Public site URL for SEO, Open Graph previews, sitemap, and canonical links.
# Example: NEXT_PUBLIC_SITE_URL=https://insureops-web.vercel.app
NEXT_PUBLIC_SITE_URL=

# Optional. If unset, the frontend hits its own Next.js API routes at /api/*.
# Set this to the URL of the real InsureOps backend (separate repo) to swap data sources.
# Example: NEXT_PUBLIC_API_BASE_URL=https://api.insureops.example.com
NEXT_PUBLIC_API_BASE_URL=
